/* ==========================================================================
   ESTILOS PARA LA BARRA DE MESES (ESTILO PÍLDORA / CÁPSULA)
   ========================================================================== */
.month-selector-wrapper {
  margin-top: 20px;
  width: 100%;
}

.month-selector {
  display: flex;
  background: linear-gradient(145deg, #f8f8fa, #f5f5f5); /* Fondo blanco del contenedor */
  border: 1px solid #e2e8f0;
  border-radius: 50px; /* Borde totalmente redondeado (píldora) */
  padding: 4px; /* Espacio interior para que la selección no toque el borde */
  gap: 4px; /* Separación entre cada botón */
  height: 48px; /* Altura ajustada */
  width: 100%;
  align-items: center;
  box-shadow: 0 2px 8px rgba(0,0,0,0.02);
}

.month-item {
  flex: 1; 
  height: 100%;
  font-size: 12px;
  font-weight: 700;
  color: #64748b;
  text-align: center;
  cursor: pointer;
  background: transparent; /* Transparente por defecto */
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 50px; /* Cada botón interior también es redondo */
  transition: all 0.25s ease;
  z-index: 1;
}

/* Efecto al pasar el mouse por encima de las opciones inactivas */
.month-item:hover:not(.active) {
  background: #f1f5f9;
  color: #2b1070;
}

/* Estilo para la opción seleccionada */
.month-item.active {
  background: #2b1070; /* Color corporativo oscuro */
  color: #ffffff;
  box-shadow: 0 2px 6px rgba(43, 16, 112, 0.25); /* Sombra suave para resaltar */
}

/* ===== Barra de meses del Panel de Casos: estilo igual a Registro de Personal (píldora deslizante) ===== */
#barraMesesDinamicaPanel .month-item {
  position: relative;
  z-index: 1;
}
/* El mes activo no lleva fondo sólido: la píldora azul deslizante va por detrás */
#barraMesesDinamicaPanel .month-item.active {
  background: transparent;
  color: #ffffff;
  box-shadow: none;
}
#barraMesesDinamicaPanel .month-item:hover:not(.active) {
  background: rgba(148, 163, 184, 0.18);
  color: #2b1070;
}

/* ==========================================================================
   DISEÑO RESPONSIVO (ADAPTACIÓN A LAPTOS Y PANTALLAS PEQUEÑAS - 1366x768)
   ========================================================================== */

/* Esta regla se activa SOLO si la pantalla mide 1400px de ancho o menos */
@media screen and (max-width: 1400px) {
  
  /* 1. Reducimos los márgenes y paddings para ganar espacio en la pantalla */
  #vistaEstadisticas,
  #vistaPanelCasos {
    padding: 20px !important; /* Menos espacio en blanco a los lados */
  }

  /* Estas dos vistas llevan barra superior pegada al sidebar: no deben recibir
     padding arriba/izquierda/derecha o se rompería la unión. */
  #vistaBaseDashboard,
  #vistaRegistroPersonal {
    padding-top: 0 !important;
    padding-left: 0 !important;
    padding-right: 0 !important;
  }

  /* 2. Las estadísticas del Médico (Fila 2 y 3) pasan de 2 columnas a 1 columna */
  /* Así evitamos que la tabla y el gráfico de anillo se aplasten */
  .stats-middle-grid,
  .stats-bottom-grid {
    grid-template-columns: 1fr !important; /* Ocupan todo el ancho disponible */
    gap: 15px;
  }

  /* 3. Ajustamos alturas para que los elementos respiren */
  .stats-box-large,
  .stats-box-donut {
    height: auto !important;
    min-height: 240px;
    padding: 20px;
  }

  /* 4. Las 4 tarjetas superiores de contadores se dividen en 2 filas de 2 */
  .cards-row-container {
    display: grid;
    grid-template-columns: repeat(2, 1fr) !important;
    gap: 15px;
  }

  /* 5. Si la tabla de pacientes principal tiene muchas columnas, permitimos scroll horizontal */
  .table-responsive {
    overflow-x: auto;
    width: 100%;
  }
}

/* ==========================================================================
   DISEÑO PARA PANTALLAS AÚN MÁS PEQUEÑAS (TABLETS O LAPTOS VIEJAS - 1024px)
   ========================================================================== */
@media screen and (max-width: 1024px) {
  /* Las 4 tarjetas superiores pasan a ser 1 sola columna */
  .cards-row-container {
    grid-template-columns: 1fr !important;
  }

  .stats-top-cards {
    display: grid;
    grid-template-columns: repeat(2, 1fr) !important;
    gap: 15px;
  }
}

