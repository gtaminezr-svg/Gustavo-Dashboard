<style>
/* ==========================================================================
   CONFIGURACIÓN GENERAL Y RESPONSIVA
   ========================================================================== */
* {
  margin: 0;
  padding: 0;
  box-sizing: border-box;
  font-family: 'Segoe UI', Arial, sans-serif;
}

:root{
  /* Paleta gris neutro (modo claro) */
  --bg:        #f0f8ff;
  --surface:   linear-gradient(145deg, #f8f8fa, #f5f5f5);
  --accent:    #004EE0;
  --accent-2:  #99CAFF;
  --accent-dk: #042E7B;
  --on-accent: #FFFFFF;
  --on-accent-2: #042E7B;
  --text:      #042E7B;
  --text-soft: #004EE0;
  /* Tarjetas (counter cards) */
  --card-bg:    linear-gradient(145deg, #f8f8fa, #f5f5f5);
  --card-border: #E9ECEF;
  --card-text:  #042E7B;
  --card-soft:  #64748b;
  --card-arrow: #E9ECEF;
  /* compatibilidad con reglas existentes */
  --dashboard-bg: var(--bg);
}
body.dark{
  /* Paleta azul (modo oscuro) */
  --bg:        #021B4D;
  --surface:   #042E7B;
  --accent:    #99CAFF;
  --accent-2:  #004EE0;
  --accent-dk: #042E7B;
  --on-accent: #042E7B;
  --on-accent-2: #FFFFFF;
  --text:      #E3F2FF;
  --text-soft: #99CAFF;
  --card-bg:    linear-gradient(145deg,#004EE0,#042E7B);
  --card-text:  #FFFFFF;
  --card-soft:  rgba(227,242,255,0.85);
  --card-arrow: rgba(255,255,255,0.35);
}

body {
  background: var(--dashboard-bg);
  color: #333;
  overflow-x: hidden;
}

/* AQUÍ PEGAS EL CÓDIGO DE LA BARRA DE DESPLAZAMIENTO */
.table-responsive::-webkit-scrollbar { width: 8px; height: 8px; }
.table-responsive::-webkit-scrollbar-track { background: #E9ECEF; border-radius: 4px; }
.table-responsive::-webkit-scrollbar-thumb { background: #E9ECEF; border-radius: 4px; }
.table-responsive::-webkit-scrollbar-thumb:hover { background: #DEE2E6; }


.app-container {
  display: flex;
  width: 100%;
  min-height: 100vh;
  position: relative;
}

/* ==========================================================================
   SIDEBAR CON UNIÓN FLUIDA (CURVA INVERTIDA)
   ========================================================================== */
.sidebar{
  position:fixed;
  top:0;
  left:0;
  height:100vh;
  width:250px;
  background:var(--surface);
  display:flex;
  flex-direction:column;
  padding:16px 14px;
  box-sizing:border-box;
  z-index:100;
  box-shadow:0 0 24px rgba(15,23,42,0.06);
  overflow:hidden;
  transition:width .28s ease, padding .28s ease;
}

/* Encabezado: logo + botón hamburguesa */
.sidebar-header{
  display:flex;
  align-items:center;
  justify-content:space-between;
  gap:10px;
  height:46px;
  margin-bottom:22px;
  padding:0 6px;
  flex-shrink:0;
}
.logo{
  display:flex;
  align-items:center;
  gap:10px;
  color:var(--text);
  font-size:20px;
  font-weight:800;
  white-space:nowrap;
  overflow:hidden;
}
.logo i{ font-size:22px; width:26px; text-align:center; flex-shrink:0; color:var(--accent); }
.rail-hamburger{
  width:38px; height:38px;
  flex-shrink:0;
  border:none; border-radius:12px;
  background:#f1f5f9; color:#475569;
  cursor:pointer; font-size:15px;
  display:flex; align-items:center; justify-content:center;
  transition:.2s;
}
.rail-hamburger:hover{ background:#e2e8f0; }

/* Menú */
nav {
  display: flex;
  flex-direction: column;
  width: 100%;
  gap: 4px;
}

.menu-item{
  display:flex;
  align-items:center;
  gap:14px;
  height:46px;
  padding:0 16px;
  border-radius:30px;
  color:#94a3b8;
  cursor:pointer;
  font-size:15px;
  font-weight:500;
  white-space:nowrap;
  overflow:hidden;
  transition:background .2s ease, color .2s ease;
}
.menu-item i{ font-size:18px; width:22px; text-align:center; flex-shrink:0; }

.menu-item:hover{
  background:#f1f5f9;
  color:#1e293b;
}

.menu-item.active{
  background:linear-gradient(90deg,var(--accent),var(--accent-dk));
  color:#ffffff;
  font-weight:600;
  box-shadow:0 8px 18px rgba(22,56,50,0.35);
}
.menu-item.active i{ color:#ffffff; }
/* Flecha indicadora a la derecha del item activo */
.menu-item.active::after{
  content:"\f054";
  font-family:"Font Awesome 6 Free";
  font-weight:900;
  font-size:11px;
  margin-left:auto;
  color:#ffffff;
}
.sidebar.collapsed .menu-item.active::after{ display:none; }

/* Pie: Cerrar Sesión + progreso */
.sidebar-footer{ margin-top:auto; width:100%; }
.menu-item.logout{ color:#ef4444; }
.menu-item.logout:hover{ background:#fef2f2; color:#dc2626; }

/* Interruptor de modo claro / oscuro (sol / luna) */
.theme-toggle{
  position:relative;
  display:flex;
  align-items:center;
  width:64px;
  height:30px;
  margin:6px 14px 14px;
  padding:3px;
  border-radius:30px;
  background:#e2e8f0;
  cursor:pointer;
  box-sizing:border-box;
  flex-shrink:0;
}
.theme-toggle .theme-ico{
  flex:1;
  display:flex;
  align-items:center;
  justify-content:center;
  font-size:12px;
  color:#94a3b8;
  z-index:1;
  transition:color .25s ease;
}
.theme-toggle .theme-sun{ color:#f59e0b; }
.theme-toggle-thumb{
  position:absolute;
  top:3px; left:3px;
  width:26px; height:24px;
  border-radius:30px;
  background:#ffffff;
  box-shadow:0 2px 5px rgba(15,23,42,0.2);
  transition:transform .25s ease;
  z-index:0;
}
.theme-toggle.dark .theme-toggle-thumb{ transform:translateX(29px); }
.theme-toggle.dark .theme-sun{ color:#94a3b8; }
.theme-toggle.dark .theme-moon{ color:#3b82f6; }
.sidebar.collapsed .theme-toggle{ display:none; }

/* Saludo "Bienvenido ..." en la barra superior */
.saludo-bloque{
  display:flex;
  flex-direction:row;
  align-items:center;
  gap:14px;
}
.saludo-icon{
  flex-shrink:0;
  width:46px;
  height:46px;
  border-radius:50%;
  background:var(--accent);
  color:var(--on-accent);
  display:flex;
  align-items:center;
  justify-content:center;
  font-size:17px;
  box-shadow:0 6px 14px rgba(0,78,224,0.28);
  transition:background .3s, box-shadow .3s;
}
.saludo-texts{
  display:flex;
  flex-direction:column;
  gap:2px;
  line-height:1.2;
}
.welcome-text{
  font-size:16px;
  font-weight:800;
  color:var(--text);
  white-space:nowrap;
}
body.dark .welcome-text{
  color:#ffffff;
}
.saludo-sub{
  font-size:11px;
  font-weight:600;
  color:#94a3b8;
  white-space:nowrap;
}
body.dark .saludo-icon{
  background:rgba(255,255,255,0.06);
  color:#C9D1E9;
  border:1px solid rgba(255,255,255,0.12);
  box-shadow:none;
}

/* Botones cápsula (Registro de Personal): estilo outline igual a "Descargar Base" */
.btn-capsula{
  display:flex;
  align-items:center;
  gap:8px;
  border:1.5px solid var(--accent);
  cursor:pointer;
  padding:9px 20px;
  border-radius:50px;
  font-size:14px;
  font-weight:700;
  white-space:nowrap;
  background:transparent;
  color:var(--accent);
  transition:background .2s ease, color .2s ease, border-color .2s ease, transform .15s ease;
}
.btn-capsula:hover{
  background:var(--accent);
  color:var(--on-accent);
  transform:translateY(-1px);
}
body.dark .btn-capsula {
  border-color: rgba(255,255,255,0.30);
  color: rgba(255,255,255,0.80);
  background: transparent;
}
body.dark .btn-capsula:hover {
  background: rgba(255,255,255,0.10);
  color: #ffffff;
  border-color: rgba(255,255,255,0.50);
}

/* ==========================================================================
   CONTENIDO PRINCIPAL Y COMPONENTES
   ========================================================================== */
.main-content {
  margin-left: 250px;
  width: calc(100% - 250px);
  padding: 20px 32px;
  background: var(--dashboard-bg);
  min-height: 100vh;
  box-sizing: border-box;
}

/* Cuando se colapsa la barra, solo quedan los iconos (76px) */
.main-content.rail-only {
  margin-left: 76px;
  width: calc(100% - 76px);
}

.search-container {
  background: var(--surface);
  height: 86px;
  padding: 0 24px;
  box-sizing: border-box;
  border-radius: 8px;
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin: 0 0 10px 0;
  box-shadow: 0 6px 18px rgba(15,23,42,0.08);
}

.search-box {
  display: flex;
  align-items: center;
  background: #f1f3f9;
  padding: 10px 16px;
  border-radius: 10px;
  width: 350px;
  gap: 10px;
}

.search-icon {
  color: #8c91a5;
}

.search-box input {
  border: none;
  background: transparent;
  width: 100%;
  outline: none;
  font-size: 14px;
  color: #333;
}

.btn-refresh {
  background: linear-gradient(145deg, #f8f8fa, #f5f5f5);
  color: #2d1b69;
  border: 1px solid #e2e8f0;
  padding: 10px 14px;
  border-radius: 10px;
  cursor: pointer;
  transition: all 0.2s;
}

.btn-refresh:hover {
  background: #f1f3f9;
  border-color: #2d1b69;
}

.cards-row-container {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
  gap: 12px;
  margin-bottom: 10px;
}

.counter-card {
  position: relative;
  background: var(--card-bg);
  padding: 20px;
  border-radius: 20px;
  border: 1px solid var(--card-border, #E9ECEF);
  box-shadow: 0 6px 18px rgba(15,23,42,0.05);
  min-width: 250px;
  min-height: 120px;
  display: flex;
  flex-direction: column;
  align-items: flex-start;
  justify-content: flex-start;
  text-align: left;
  gap: 8px;
  overflow: hidden;
  transition: box-shadow .2s ease, transform .2s ease;
}
.counter-card:hover{
  box-shadow: 0 10px 26px rgba(15,23,42,0.09);
  transform: translateY(-2px);
}

/* Fila superior: círculo + etiqueta */
.card-top-row {
  display: flex;
  align-items: center;
  justify-content: flex-start;
  align-self: flex-start;
  position: relative;
  z-index: 1;
  gap: 10px;
}

/* Círculo semáforo */
.card-dot {
  width: 22px;
  height: 22px;
  border-radius: 50%;
  flex-shrink: 0;
  background: #cbd5e1;
  transition: background .3s ease, box-shadow .3s ease;
}

/* Colores del círculo según tipo de card */
.border-left-pendiente .card-dot   { background: #dc3545; }
.border-left-proceso .card-dot     { background: #ffc107; }
.border-left-resultados .card-dot  { background: #28a745; }
.border-left-total .card-dot       { background: #004EE0; }
.border-left-vencer .card-dot      { background: #cbd5e1; }
.border-left-warning .card-dot     { background: #cbd5e1; }
.border-left-mes .card-dot         { background: #8b5cf6; }

/* Borde izquierdo queda solo como acento fino */
.border-left-pendiente  { border-left: 4px solid #dc3545; }
.border-left-proceso    { border-left: 4px solid #ffc107; }
.border-left-resultados { border-left: 4px solid #28a745; }
.border-left-total      { border-left: 4px solid #004EE0; }
.border-left-vencer     { border-left: 4px solid #f59e0b; }
.border-left-warning    { border-left: 4px solid #166534; }
.border-left-mes        { border-left: 4px solid #8b5cf6; }

/* Número: marca de agua abajo-derecha */
.counter-number {
  font-size: 130px;
  font-weight: 900;
  letter-spacing: 0;
  line-height: 1;
  color: rgba(180, 186, 194, 0.80);
  position: absolute;
  bottom: -32px;
  right: 4px;
  z-index: 0;
  pointer-events: none;
}

.counter-label {
  font-size: 14px;
  font-weight: 700;
  color: var(--card-soft);
  position: relative;
  z-index: 1;
  align-self: flex-start;
  text-align: left;
  text-transform: uppercase;
  letter-spacing: .3px;
}

.table-card {
  background: linear-gradient(145deg, #E9ECEF, #F3F9FA);
  border-radius: 20px;
  padding: 28px 36px;
  border: 1px solid #E9ECEF;
  box-shadow: 0 6px 18px rgba(15,23,42,0.05);
}

.table-header-container {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 10px;
}

.table-title {
  font-size: 18px;
  color: #2d1b69;
  font-weight: 700;
  letter-spacing: -0.3px;
}

.btn-primary {
  background: #2d1b69;
  color: white;
  border: none;
  padding: 12px 20px;
  border-radius: 10px;
  font-weight: 600;
  cursor: pointer;
  font-size: 14px;
  transition: background 0.2s;
}

.btn-primary:hover {
  background: #1e114a;
}

.table-responsive {
  width: 100%;
  overflow-x: auto;
}

.custom-table {
  width: 100%;
  border-collapse: collapse;
  text-align: left;
}

.custom-table th {
  background: #f8fafc;
  padding: 14px 16px;
  font-size: 11px;
  font-weight: 700;
  letter-spacing: 0.5px;
  text-transform: uppercase;
  color: #94a3b8;
  border-bottom: 1px solid #eef2f7;
}

.custom-table td {
  padding: 16px 16px;
  border-bottom: 1px solid #f5f7fa;
  font-size: 14px;
  vertical-align: middle;
}
.custom-table tbody tr:last-child td {
  border-bottom: none;
}

.patient-name-click {
  color: #2d1b69;
  font-weight: 600;
  cursor: pointer;
}

.patient-name-click:hover {
  text-decoration: underline;
}

.row-main-text {
  font-weight: 500;
  color: #334155;
}

.row-sub-text {
  font-size: 12px;
  color: #64748b;
  margin-top: 2px;
}

.btn-table-view {
  background: #f1f5f9;
  color: #2d1b69;
  border: 1px solid #cbd5e1;
  padding: 8px 14px;
  border-radius: 8px;
  cursor: pointer;
  font-size: 13px;
  font-weight: 600;
  display: inline-flex;
  align-items: center;
  gap: 6px;
  transition: all 0.2s;
}

.btn-table-view:hover {
  background: #2d1b69;
  color: white;
  border-color: #2d1b69;
}

.badge {
  padding: 6px 14px;
  border-radius: 20px;
  font-size: 12px;
  font-weight: 600;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  max-width: 280px;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.badge-danger {background: #f5f505; color: #000000; border: 0px solid #d4d400; font-weight: 700;}
.badge-success {background: #117a13; color: #ffffff; border: 1px solid #117a13; font-weight: 700;}

.pagination-container {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-top: 10px;
  padding-top: 10px;
  border-top: 1px solid #f1f5f9;
}

.pagination-info {
  font-size: 14px;
  color: #64748b;
}

.pagination-buttons {
  display: flex;
  gap: 8px;
}

.btn-nav {
  padding: 8px 16px;
  border: 1px solid #e2e8f0;
  background: linear-gradient(145deg, #f8f8fa, #f5f5f5);
  border-radius: 8px;
  cursor: pointer;
  font-size: 13px;
  color: #334155;

  transition:
    background-color 0.2s ease,
    color 0.2s ease,
    border-color 0.2s ease,
    transform 0.15s ease;
}

/* EFECTO HOVER */
.btn-nav:not(:disabled):hover {
  background: #2d1b69;
  color: white;
  border-color: #2d1b69;
  transform: translateY(-1px);
}

/* BOTONES DESACTIVADOS */
.btn-nav:disabled {
  background: #f8fafc;
  color: #cbd5e1;
  cursor: not-allowed;
  opacity: 0.6;
}

/* ==========================================================================
   MODAL DE CONTROL
   ========================================================================== */
.modal-overlay {
  position: fixed;
  top: 0;
  left: 0;
  width: 100vw;
  height: 100vh;
  background: rgba(15, 23, 42, 0.6);
  backdrop-filter: blur(4px);
  display: flex;
  justify-content: center;
  align-items: center;
  z-index: 9999;
  opacity: 0;
  pointer-events: none;
  transition: opacity 0.3s ease;
}

.modal-overlay.active {
  opacity: 1;
  pointer-events: auto;
}

.modal-content {
  background: linear-gradient(145deg, #f8f8fa, #f5f5f5);
  width: 780px;
  max-width: 95%;
  border-radius: 16px;
  padding: 20px 24px;
  overflow: hidden;
  box-shadow: 0 20px 25px -5px rgba(0, 0, 0, 0.1);
}

.modal-header-inline {
  display: flex;
  justify-content: space-between;
  align-items: center;
  border-bottom: 1px solid #e2e8f0;
  margin-bottom: 14px;
  padding-bottom: 8px;
}

.modal-title {
  font-size: 19px;
  color: #2d1b69;
  font-weight: 600;
}

.btn-inline-edit {
  background: #fff;
  color: #2d1b69;
  border: 1px solid #2d1b69;
  padding: 8px 14px;
  border-radius: 8px;
  font-weight: 600;
  cursor: pointer;
  font-size: 13px;
  transition: all 0.2s;
}

.btn-inline-edit:hover {
  background: #2d1b69;
  color: white;
}

.form-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 10px;
}

.col-span-2 {
  grid-column: span 2;
}

.form-group {
  display: flex;
  flex-direction: column;
  gap: 4px;
}

.form-group label {
  font-size: 12px;
  font-weight: 600;
  color: #475569;
}

.form-group input, .form-group select, .form-group textarea {
  padding: 8px 12px;
  border: 1px solid #cbd5e1;
  border-radius: 8px;
  font-size: 13px;
  outline: none;
  background: #f4f6fa;
  color: #1e293b;
  transition: all 0.2s ease-in-out;
}

.form-group input:focus, .form-group select:focus, .form-group textarea:focus {
  background: linear-gradient(145deg, #f8f8fa, #f5f5f5);
  border-color: #2d1b69;
}

.flex-row-align {
  display: flex;
  gap: 10px;
  align-items: center;
  width: 100%;
}

.btn-cancel {
  background: #f1f5f9;
  color: #475569;
  border: 1px solid #cbd5e1;
  padding: 10px 18px;
  border-radius: 8px;
  font-weight: 600;
  cursor: pointer;
  font-size: 13px;
  transition: all 0.2s;
}

.btn-cancel:hover {
  background: #e2e8f0;
}

.subestado-label-wrapper {
  display: flex;
  align-items: center;
  gap: 6px;
}

.subestado-dot-indicator {
  width: 8px;
  height: 8px;
  border-radius: 50%;
  background-color: #cbd5e1;
  display: inline-block;
  flex-shrink: 0;
  box-shadow: inset 0 0 2px rgba(0,0,0,0.2);
}

.specialty-badge-box, .insurance-badge-box {
  display: inline-flex;
  align-items: center;
  gap: 6px;
  padding: 6px 12px;
  border-radius: 6px;
  font-size: 12px;
  font-weight: 600;
  white-space: nowrap;
  transition: all 0.2s ease;
  height: 36px;
}

.subestado-badge-box{
  display:inline-flex;
  align-items:center;
  gap:6px;
  padding:6px 12px;
  border-radius:6px;
  font-size:12px;
  font-weight:600;
  white-space:nowrap;
  height:36px;
  cursor:pointer;
  transition:all .2s ease;

  background:#14532d;
  color:#dcfce7;
  border:1px solid #166534;
}

.subestado-badge-box:hover{
  transform:scale(1.03);
}

/* ==========================================================================
   NUEVOS COLORES SOLICITADOS PARA LOS SEGUROS
   ========================================================================== */
.bg-seguro-rojo {
  background: #fef2f2;
  color: #b91c1c;
  border: 1px solid #fee2e2;
}

.bg-seguro-anaranjado {
  background: #fff7ed;
  color: #ea580c;
  border: 1px solid #ffedd5;
}

.bg-seguro-verde {
  background: #f0fdf4;
  color: #166534;
  border: 1px solid #bbf7d0;
}

.bg-seguro-dorado {
  background: #fefce8;
  color: #a16207;
  border: 1px solid #fef08a;
}

/* Otros estilos por defecto de respaldo */
.bg-general {
  background: #f0fdfa;
  color: #0d9488;
  border: 1px solid #ccfbf1;
}

.bg-pediatria {
  background: #f5ebeb;
  color: #db5e5e;
  border: 1px solid #fca5a5;
}

.bg-eps {
  background: #f8fafc;
  color: #475569;
  border: 1px solid #e2e8f0;
}

/* ==========================================================================
   CAMBIO: EXÁMENES PINTADOS DE PÚRPURA
   ========================================================================== */
.exams-tags-container {
